{
  "name": "flowdesk-task-handoff",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:desktop": "VITE_DESKTOP=true vite --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "build:desktop": "VITE_DESKTOP=true vite build",
    "preview": "vite preview --host 0.0.0.0",
    "tauri": "tauri",
    "desktop:dev": "npm run tauri -- dev",
    "desktop:build:mac": "npm run tauri -- build --bundles app,dmg --no-sign"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
